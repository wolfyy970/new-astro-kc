---
/**
 * CaptionedImage — Image at its native aspect ratio with a single caption line.
 *
 * The image renders at its intrinsic proportions — no cropping, no forcing.
 * Landscape images fill the content width. Portrait images center themselves
 * at their natural width (capped at the content area).
 *
 * Use this when the work should speak for itself.
 */

interface Props {
    image: string;
    imageAlt: string;
    caption?: string;
    label?: string;
}

const { image, imageAlt, caption, label } = Astro.props;
---

<section class="captioned-image-section">
    <div class="captioned-image-inner">
        {label && <p class="image-label">{label}</p>}
        <div class="captioned-image-frame">
            <img
                src={image}
                alt={imageAlt}
                loading="lazy"
                decoding="async"
            />
        </div>
        {caption && <p class="image-caption">{caption}</p>}
    </div>
</section>

<style>
    .captioned-image-section {
        padding: 80px;
    }

    .captioned-image-inner {
        max-width: 1600px;
        margin: 0 auto;
    }

    .image-label {
        font-size: 11px;
        font-weight: 600;
        letter-spacing: 3px;
        text-transform: uppercase;
        color: var(--accent, currentColor);
        margin-bottom: 24px;
        opacity: 0.8;
    }

    /*
     * The frame is a flex container so portrait images center themselves
     * rather than stretching. The image never exceeds its container and
     * never exceeds its natural pixel width — it renders at exactly what
     * the source deserves.
     */
    .captioned-image-frame {
        border-radius: 12px;
        overflow: hidden;
        background: #f0ede8;
        line-height: 0;
        display: flex;
        justify-content: center;
    }

    .captioned-image-frame img {
        /* Landscape: fills the container width.
           Portrait:  capped at its natural width, centered. */
        max-width: 100%;
        height: auto;
        display: block;
        border-radius: inherit;
    }

    .image-caption {
        margin-top: 20px;
        font-size: 14px;
        font-weight: 400;
        color: var(--text-secondary, #666);
        line-height: 1.5;
        max-width: 680px;
        font-style: italic;
    }

    @media (max-width: 1024px) {
        .captioned-image-section { padding: 64px 32px; }
    }

    @media (max-width: 600px) {
        .captioned-image-section { padding: 48px 24px; }
    }
</style>

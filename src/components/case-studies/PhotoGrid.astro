---
/**
 * PhotoGrid — A grid of images with no per-image text.
 *
 * Images render at their native aspect ratio — no cropping, no forced fit.
 * Each image fills the full width of its column; height follows naturally.
 *
 * IMPORTANT: only group images with similar aspect ratios (all portrait or
 * all landscape) in the same PhotoGrid. Mixing portrait and landscape images
 * in one grid creates uneven row heights.
 *
 * Use when you want to show a body of work as a coherent visual statement.
 */

interface PhotoItem {
    src: string;
    alt: string;
}

interface Props {
    images: PhotoItem[];
    /** Grid column count (1–4). Collapses on smaller screens. Default: 2. */
    columns?: 1 | 2 | 3 | 4;
    /** Short eyebrow label above the grid. */
    label?: string;
    /** Optional section heading. Keep it brief. */
    title?: string;
    /** Inter-image gap size. Default: "normal" (16px). */
    gap?: "tight" | "normal" | "loose";
}

const { images, columns = 2, label, title, gap = "normal" } = Astro.props;
---

<section class={`photo-grid-section photo-grid-section--gap-${gap}`}>
    <div class="photo-grid-inner">
        {(label || title) && (
            <header class="photo-grid-header">
                {label && <p class="photo-label">{label}</p>}
                {title && <h2 class="photo-title">{title}</h2>}
            </header>
        )}
        <div class={`photo-grid photo-grid--cols-${columns}`}>
            {images.map(img => (
                <div class="photo-item">
                    <img
                        src={img.src}
                        alt={img.alt}
                        loading="lazy"
                        decoding="async"
                    />
                </div>
            ))}
        </div>
    </div>
</section>

<style>
    .photo-grid-section {
        padding: 80px;
    }

    .photo-grid-inner {
        max-width: 1600px;
        margin: 0 auto;
    }

    .photo-grid-header {
        margin-bottom: 40px;
    }

    .photo-label {
        font-size: 11px;
        font-weight: 600;
        letter-spacing: 3px;
        text-transform: uppercase;
        color: var(--accent, currentColor);
        opacity: 0.8;
        margin-bottom: 12px;
    }

    .photo-title {
        font-family: 'Playfair Display', serif;
        font-size: clamp(24px, 3vw, 36px);
        font-weight: 400;
        color: var(--text-primary, #1a1a1a);
        line-height: 1.2;
    }

    .photo-grid {
        display: grid;
        gap: 16px;
    }

    .photo-grid-section--gap-tight  .photo-grid { gap: 6px; }
    .photo-grid-section--gap-normal .photo-grid { gap: 16px; }
    .photo-grid-section--gap-loose  .photo-grid { gap: 32px; }

    .photo-grid--cols-1 { grid-template-columns: 1fr; }
    .photo-grid--cols-2 { grid-template-columns: repeat(2, 1fr); }
    .photo-grid--cols-3 { grid-template-columns: repeat(3, 1fr); }
    .photo-grid--cols-4 { grid-template-columns: repeat(4, 1fr); }

    .photo-item {
        border-radius: 10px;
        overflow: hidden;
        background: #f0ede8;
        line-height: 0;
    }

    /*
     * Images fill their column width. Height follows the native aspect ratio.
     * No cropping. No object-fit forcing.
     */
    .photo-item img {
        width: 100%;
        height: auto;
        display: block;
    }

    @media (max-width: 1024px) {
        .photo-grid-section {
            padding: 64px 32px;
        }
        .photo-grid--cols-3,
        .photo-grid--cols-4 {
            grid-template-columns: repeat(2, 1fr);
        }
    }

    @media (max-width: 600px) {
        .photo-grid-section {
            padding: 48px 24px;
        }
        .photo-grid--cols-2,
        .photo-grid--cols-3,
        .photo-grid--cols-4 {
            grid-template-columns: 1fr;
        }
    }
</style>
